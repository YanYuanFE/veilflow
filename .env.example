# WalletConnect / Reown Cloud project id (https://cloud.reown.com) for RainbowKit.
# Injected wallets (MetaMask) work without it; WalletConnect needs a real id.
VITE_WALLETCONNECT_PROJECT_ID=

# Neon Postgres connection string (https://neon.tech). Used by the /api functions
# (vercel dev) and Drizzle migrations. Never exposed to the browser.
DATABASE_URL=

# SIWE session signing secret (HMAC). Generate with: openssl rand -hex 32
# Required by the /api auth functions (api/_auth.ts). Set in Vercel env vars for prod.
AUTH_SECRET=
