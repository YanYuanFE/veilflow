# Sepolia RPC endpoint (Alchemy / Infura / public node).
# Falls back to a public node if unset. Used by wagmi transport and the Zama relayer.
VITE_SEPOLIA_RPC_URL=

# WalletConnect / Reown Cloud project id (https://cloud.reown.com) for RainbowKit.
# Injected wallets (MetaMask) work without it; WalletConnect needs a real id.
VITE_WALLETCONNECT_PROJECT_ID=
